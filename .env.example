# Copia este archivo como ".env" y completa tus valores.
# Arranca cargando el .env:  node --env-file=.env server.js
# NUNCA subas el archivo .env real a GitHub.

# Puerto del servidor
PORT=3000

# Token secreto compartido con Vapi (debe coincidir con el "secret" del tool)
WEBHOOK_SECRET=

# --- Notificacion por Telegram (la mas facil y gratis) ---
# 1) Crea un bot con @BotFather y copia el token.
# 2) Obten tu chat_id (escribele a @userinfobot).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Notificacion por WhatsApp via Twilio (opcional) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
DUENO_WHATSAPP_TO=whatsapp:+569XXXXXXXX
