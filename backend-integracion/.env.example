# Copia este archivo como ".env" y completa tus valores.
# NUNCA subas el archivo .env real a GitHub.

# Puerto del servidor
PORT=3000

# Token secreto compartido con Vapi (debe coincidir con el "secret" del tool)
WEBHOOK_SECRET=cambia-esto-por-un-token-largo-y-secreto

# --- Notificación por Telegram (la más fácil y gratis) ---
# 1) Crea un bot con @BotFather y copia el token.
# 2) Obtén tu chat_id (puedes usar @userinfobot).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Notificación por WhatsApp vía Twilio (opcional) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
DUENO_WHATSAPP_TO=whatsapp:+569XXXXXXXX
